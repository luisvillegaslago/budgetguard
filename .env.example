# Database (PostgreSQL — primary, used by the app)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/budgetguard

# Backup Database (dev-only, used by Settings > Database Backup panel)
# BACKUP_DATABASE_URL=postgresql://postgres:your_password@localhost:5432/budgetguard_backup

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Vercel Blob (Fiscal Documents)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-read-write-token

# Anthropic API (OCR)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Crypto module — master key for AES-256-GCM encryption of exchange API keys.
# Generate with:  openssl rand -base64 32
# Rotate by bumping the EncryptionKeyVersion in src/utils/cryptoSecrets.ts.
# WARNING: losing this key makes all stored Binance credentials unreadable.
CRYPTO_MASTER_KEY=base64-encoded-32-byte-key

# Vercel Cron secret — required for /api/cron/crypto-sync.
# Generate with:  openssl rand -base64 32
# In Vercel, set the same value as the cron Authorization header.
CRON_SECRET=base64-encoded-secret

# Verbose server-side logging for the Binance sync worker.
# Logs discovery sources, per-endpoint event counts, and full error causes
# (with binanceCode) for each task failure. Leave unset/empty in production.
# CRYPTO_SYNC_DEBUG=1