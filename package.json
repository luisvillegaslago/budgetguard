{
  "name": "budgetguard",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check src",
    "lint-and-types": "tsc --noEmit --pretty --incremental && biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "format-and-lint": "biome check --write src",
    "check-types": "tsc --noEmit --pretty",
    "prepare": "husky",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "release": "node scripts/smart-release.js",
    "release:first": "commit-and-tag-version --first-release",
    "release:patch": "commit-and-tag-version --release-as patch",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "release:dry-run": "node scripts/smart-release.js --dry-run"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.5",
    "@hookform/resolvers": "^4.1.3",
    "@neondatabase/serverless": "^1.0.2",
    "@tanstack/react-query": "^5.66.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.479.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.11",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-datepicker": "^7.6.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.55.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.1.1",
    "@types/react-datepicker": "^7.0.0",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "commit-and-tag-version": "^12.6.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.3",
    "ts-jest": "^29.4.6",
    "typescript": "5.4.5"
  }
}
